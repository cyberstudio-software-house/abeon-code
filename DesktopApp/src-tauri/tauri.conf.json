{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AbeonCode",
  "version": "0.1.6",
  "identifier": "pl.cyberstudio.abeoncode",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AbeonCode",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": [
          "abeon-code"
        ]
      }
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDlBQUQxMDlCMTY5RDAwMjUKUldRbEFKMFdteEN0bXA3VWM3by9UMGxqQVAzU3lJZk0vVzVZd2tFNmE2YUxGNDFqUXQ0cDJZVjAK",
      "endpoints": [
        "https://github.com/cyberstudio-software-house/abeon-code/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
